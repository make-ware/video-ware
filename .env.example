# PocketBase Configuration
POCKETBASE_URL=http://localhost:8090
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=your-secure-password

# Next.js Configuration
NEXT_PUBLIC_POCKETBASE_URL=http://localhost:8090

# Redis Configuration (required for Worker)
# Format: redis://:password@host:port or redis://host:port
REDIS_URL=redis://localhost:6379

# Bull Board Configuration
# Port to expose the Bull Board UI on the worker
BULL_BOARD_PORT=3002

# Storage Configuration
# Backend type: 'local' or 's3' (default: local)
STORAGE_TYPE=local

# Worker Data Directory
# Path for temporary processing files
WORKER_DATA_DIR=./data

# ============================================================================
# Worker Tuning (optional — all have sensible defaults; shown commented out)
# ============================================================================
# HTTP port for the worker's health/metrics endpoint
# PORT=3001

# Redis connection components — used only as a fallback when REDIS_URL is empty
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Log verbosity: verbose | debug | info | warn | error
# LOG_LEVEL=info

# S3 Storage Configuration (required when STORAGE_TYPE=s3)
# STORAGE_S3_ENDPOINT=https://s3.amazonaws.com
# STORAGE_S3_BUCKET=your-bucket-name
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_ACCESS_KEY_ID=your-access-key
# STORAGE_S3_SECRET_ACCESS_KEY=your-secret-key
# STORAGE_S3_FORCE_PATH_STYLE=false

# Watch-folder import (S3 only). The worker polls the bucket prefix for
# drop-ins laid out as {prefix}{workspaceId}/[{dir}/]{file}, waits out the
# quiet period after each object's LastModified, then imports it through the
# normal upload pipeline. Every attempted (key, etag) pair is recorded in the
# WatchFolderImports collection and never retried.
# ENABLE_WATCH_FOLDER=false
# WATCH_FOLDER_PREFIX=import/
# WATCH_FOLDER_QUIET_PERIOD_MS=900000
# WATCH_FOLDER_POLL_INTERVAL_MS=60000

# ============================================================================
# Google Cloud Configuration
# ============================================================================
# Configuration for Google Cloud services (Video Intelligence, Speech-to-Text, Transcoder)
# See GCVI Processor Configuration section below for granular processor control

# Google Cloud Project ID (required for all Google Cloud services)
# GOOGLE_PROJECT_ID=your-gcp-project-id

# Google Cloud Credentials (choose one option):
# Option 1: Inline JSON credentials (recommended for deployment)
# GOOGLE_CLOUD_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"..."}
# Option 2: Path to key file (good for local development)
# GOOGLE_CLOUD_KEY_FILE=/path/to/service-account-key.json
# Option 3: Omit both to use Application Default Credentials (gcloud auth)

# GCS Bucket for temporary file uploads (required when using local storage with Google Cloud services)
# GCS_BUCKET=your-gcs-bucket-name

# Google Transcoder Configuration (optional)
# ENABLE_GOOGLE_TRANSCODER=false

# ============================================================================
# Google Cloud Video Intelligence Processor Configuration
# ============================================================================
# Granular control over Google Cloud Video Intelligence API processors
# Enable/disable individual processors for cost optimization and feature control
# Each processor makes a separate API call with specific features.
#
# ALL processors are DISABLED by default. A flag is only "on" when it is set to
# the exact string 'true'; unset, empty, or any other value means disabled, and
# label detection performs no work (no API calls, no DB writes).

# Processor Enablement Flags
# ---------------------------
# Label Detection: Detects labels (objects, activities, locations) and shot changes
# Use case: Content categorization, scene detection
ENABLE_LABEL_DETECTION=false

# Object Tracking: Tracks objects across frames with bounding boxes and keyframes
# Use case: Object movement analysis, security footage
ENABLE_OBJECT_TRACKING=false

# Face Detection: Detects and tracks faces with attributes (glasses, headwear, etc.)
# Use case: Face presence detection, crowd analysis
ENABLE_FACE_DETECTION=false

# Person Detection: Detects and tracks persons with pose landmarks and attributes
# Use case: Person tracking, activity recognition
ENABLE_PERSON_DETECTION=false

# Text Detection: OCRs on-screen text with per-frame bounding boxes
# Use case: Signs, titles, captions burned into the video, product names
ENABLE_TEXT_DETECTION=false

# Speech Transcription: Transcribes speech to text with word-level timestamps
# Use case: Subtitles, content search, accessibility
ENABLE_SPEECH_TRANSCRIPTION=false

# ============================================================================
# ElevenLabs Speaker Transcription Configuration
# ============================================================================
# Speaker Transcription: word-precise STT with speaker diarization via
# ElevenLabs Scribe (scribe_v2, up to 32 speakers). Populates the LabelSpeaker
# collection so the editor can see who says what, when (Q&A-style editing).
# Not a GCVI processor: needs ELEVENLABS_API_KEY, not Google credentials, and
# reads media from app storage (no GCS upload).
# Use case: Interview/Q&A editing, per-speaker transcripts
ENABLE_SPEAKER_TRANSCRIPTION=false

# ElevenLabs API key (required when ENABLE_SPEAKER_TRANSCRIPTION=true)
# ELEVENLABS_API_KEY=your-elevenlabs-api-key

# GCVI API Configuration
# ----------------------
# Google Cloud Project ID (required for all GCVI processors)
# GOOGLE_PROJECT_ID=your-gcp-project-id

# Google Cloud Credentials (choose one option):
# Option 1: Inline JSON credentials (recommended for deployment)
# GOOGLE_CLOUD_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"..."}
# Option 2: Path to key file (good for local development)
# GOOGLE_CLOUD_KEY_FILE=/path/to/service-account-key.json
# Option 3: Omit both to use Application Default Credentials (gcloud auth)

# GCS Bucket for temporary file uploads (required when using local storage)
# GCS_BUCKET=your-gcs-bucket-name

# Processing Configuration
# ------------------------
# Confidence thresholds for filtering results (0.0 - 1.0)
# Higher values = fewer results but higher quality
LABEL_DETECTION_CONFIDENCE_THRESHOLD=0.2
OBJECT_TRACKING_CONFIDENCE_THRESHOLD=0.5
FACE_DETECTION_CONFIDENCE_THRESHOLD=0.7
PERSON_DETECTION_CONFIDENCE_THRESHOLD=0.7

# Label Detection Mode
# SHOT_MODE: Detect labels at shot level only (faster, cheaper)
# SHOT_AND_FRAME_MODE: Detect labels at both shot and frame level (more detailed)
LABEL_DETECTION_MODE=SHOT_AND_FRAME_MODE

# Speech Transcription Configuration
SPEECH_TRANSCRIPTION_LANGUAGE=en-US
SPEECH_TRANSCRIPTION_ENABLE_PUNCTUATION=true

# Face Detection Configuration
FACE_DETECTION_INCLUDE_BOUNDING_BOXES=true
FACE_DETECTION_INCLUDE_ATTRIBUTES=true

# Person Detection Configuration
PERSON_DETECTION_INCLUDE_BOUNDING_BOXES=true
PERSON_DETECTION_INCLUDE_POSE_LANDMARKS=true
PERSON_DETECTION_INCLUDE_ATTRIBUTES=true

# Development
NODE_ENV=development

# CLI (vw) login credentials for local development
VW_EMAIL=user@example.com
VW_PASSWORD=your-password
